# Required: Google Gemini API key for parsing natural-language route queries.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Google Maps API key for better geocoding and routing (US road names).
# If set, Geocoding and Directions APIs are used instead of Nominatim and OSRM.
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
